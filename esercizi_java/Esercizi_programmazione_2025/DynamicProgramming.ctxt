comment8.text=\r\n\ (define\ stirling\r\n\ \ \ \ \ \ (lambda\ (n\ k)\ \ \ ;\ n,k\:\ interi\ positivi\ t.c.\ [1<\=k<\=n]\r\n\ \ \ \ \ \ \ \ ;\ ricorsione\r\n\ \ \ \ \ \ \ \ (if\ (or\ (\=\ k\ 1)\ (\=\ k\ n))\r\n\ \ \ \ \ \ \ \ \ \ \ \ 1\r\n\ \ \ \ \ \ \ \ \ \ \ \ (+\ (stirling\ (-\ n\ 1)\ (-\ k\ 1))\ \ \ ;\ (k\ >\ 1)\ dispongo\ i\ pasticcini\ in\ tutti\ -\ quello\ del\ canestrello\r\n\ \ \ \ \ \ \ \ \ \ \ \ \ \ \ (*\ k\ (stirling\ (-\ n\ 1)\ k))\ \ ;\ (k\ <\ n)\ dispongo\ l'altro,\ meno\ s\u00E9\ stesso\ in\ tutti\ gli\ altri.\r\n\ \ \ \ \ \ \ \ \ \ \ \ \ \ \ ))\r\n\ \ \ \ \ \ \ \ ))\r\n
